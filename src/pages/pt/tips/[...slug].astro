---
import { getCollection } from 'astro:content';
import TipView from '../../../components/views/TipView.astro';

export async function getStaticPaths() {
  const tips = await getCollection('tips', ({ id, data }) => !data.draft && id.startsWith('pt/'));
  return tips.map((tip) => ({
    params: { slug: tip.id.replace(/^pt\//, '') },
    props: { tip },
  }));
}

const { tip } = Astro.props;
---

<TipView locale="pt" tip={tip} />
