---
import { getCollection } from 'astro:content';
import BikeView from '../../../components/views/BikeView.astro';

export async function getStaticPaths() {
  const bikes = await getCollection(
    'bikes',
    ({ data }) => !data.draft && data.status !== 'wishlist',
  );
  return bikes.map((bike) => ({ params: { slug: bike.id }, props: { bike } }));
}

const { bike } = Astro.props;
---

<BikeView locale="pt" bike={bike} />
