---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import TripCard from '../components/TripCard.astro';
import BikeCard from '../components/BikeCard.astro';
import { url } from '../lib/url';

const trips = (await getCollection('trips', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

const bikes = (await getCollection('bikes', ({ data }) => !data.draft)).sort((a, b) =>
  a.data.status.localeCompare(b.data.status),
);
---

<Layout>
  <section class="mb-14">
    <h1 class="font-mono text-3xl font-semibold tracking-tight sm:text-4xl">
      Documenting the ride.
    </h1>
    <p class="mt-3 max-w-prose text-[var(--color-muted)]">
      Trips, hard-won tips, the bikes in (and out of) the garage, and every wrench turned —
      logged so I don't have to remember it all.
    </p>
  </section>

  <section class="mb-14">
    <div class="mb-4 flex items-baseline justify-between">
      <h2 class="font-mono text-xl font-semibold">Latest trips</h2>
      <a href={url('/trips')} class="font-mono text-sm text-[var(--color-accent)] hover:underline">
        all trips →
      </a>
    </div>
    <div class="grid gap-5 sm:grid-cols-2">
      {trips.map((trip) => <TripCard trip={trip} />)}
    </div>
  </section>

  <section>
    <div class="mb-4 flex items-baseline justify-between">
      <h2 class="font-mono text-xl font-semibold">The garage</h2>
      <a href={url('/bikes')} class="font-mono text-sm text-[var(--color-accent)] hover:underline">
        bike catalog →
      </a>
    </div>
    <div class="grid gap-5 sm:grid-cols-2">
      {bikes.map((bike) => <BikeCard bike={bike} />)}
    </div>
  </section>
</Layout>
