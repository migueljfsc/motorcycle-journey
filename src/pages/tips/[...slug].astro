---
import { getCollection } from 'astro:content';
import TipView from '../../components/views/TipView.astro';

export async function getStaticPaths() {
  const tips = await getCollection('tips', ({ id, data }) => !data.draft && id.startsWith('en/'));
  return tips.map((tip) => ({
    params: { slug: tip.id.replace(/^en\//, '') },
    props: { tip },
  }));
}

const { tip } = Astro.props;
---

<TipView locale="en" tip={tip} />
