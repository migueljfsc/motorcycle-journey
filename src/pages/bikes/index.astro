---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BikeCard from '../../components/BikeCard.astro';

const bikes = await getCollection('bikes', ({ data }) => !data.draft);

const order = { owned: 0, past: 1, wishlist: 2 } as const;
const groups = [
  { status: 'owned' as const, label: 'In the garage' },
  { status: 'past' as const, label: 'Previously owned' },
  { status: 'wishlist' as const, label: 'On the wishlist' },
];
const sorted = bikes.sort((a, b) => order[a.data.status] - order[b.data.status]);
---

<Layout title="Bikes" description="The bike catalog — owned, past, and wished-for.">
  <h1 class="mb-6 font-mono text-3xl font-semibold tracking-tight">The garage</h1>

  {
    groups.map((g) => {
      const inGroup = sorted.filter((b) => b.data.status === g.status);
      if (inGroup.length === 0) return null;
      return (
        <section class="mb-10">
          <h2 class="mb-4 font-mono text-sm uppercase tracking-wide text-[var(--color-muted)]">
            {g.label}
          </h2>
          <div class="grid gap-5 sm:grid-cols-2">
            {inGroup.map((bike) => (
              <BikeCard bike={bike} />
            ))}
          </div>
        </section>
      );
    })
  }
</Layout>
