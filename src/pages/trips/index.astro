---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import TripCard from '../../components/TripCard.astro';

const trips = (await getCollection('trips', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout title="Trips" description="Ride reports from the road.">
  <h1 class="mb-6 font-mono text-3xl font-semibold tracking-tight">Trips</h1>
  <div class="grid gap-5 sm:grid-cols-2">
    {trips.map((trip) => <TripCard trip={trip} />)}
  </div>
</Layout>
