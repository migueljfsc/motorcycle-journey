---
import { media } from '../lib/url';
import { photoPosition } from '../data/media';

interface Props {
  images: string[];
  alt?: string;
}
const { images, alt = '' } = Astro.props;
const single = images.length <= 1;
---

<div
  class="moto-carousel relative overflow-hidden rounded-lg border border-[var(--color-border)] bg-[var(--color-card)]"
  data-carousel
>
  <div
    class="track flex aspect-[3/2] snap-x snap-mandatory overflow-x-auto scroll-smooth"
    data-track
  >
    {
      images.map((src) => (
        <img
          src={media(src)}
          alt={alt}
          style={`object-position: ${photoPosition[src] ?? 'center'}`}
          class="aspect-[3/2] w-full min-w-0 shrink-0 grow-0 basis-full cursor-zoom-in snap-center object-cover"
          loading="lazy"
          data-slide-img
        />
      ))
    }
  </div>

  {
    !single && (
      <>
        <button
          type="button"
          data-prev
          aria-label="Previous photo"
          class="absolute left-2 top-1/2 -translate-y-1/2 rounded-full border border-[var(--color-border)] bg-[var(--color-bg)]/80 px-3 py-1.5 font-mono text-sm backdrop-blur transition-colors hover:text-[var(--color-accent)]"
        >
          ‹
        </button>
        <button
          type="button"
          data-next
          aria-label="Next photo"
          class="absolute right-2 top-1/2 -translate-y-1/2 rounded-full border border-[var(--color-border)] bg-[var(--color-bg)]/80 px-3 py-1.5 font-mono text-sm backdrop-blur transition-colors hover:text-[var(--color-accent)]"
        >
          ›
        </button>
        <div
          data-dots
          class="absolute inset-x-0 bottom-3 flex justify-center gap-2"
        >
          {images.map((_, i) => (
            <span
              data-dot={i}
              class="h-2 w-2 rounded-full bg-[var(--color-muted)] opacity-50 transition-opacity"
            />
          ))}
        </div>
      </>
    )
  }

  {/* Full-image lightbox: shows the whole, uncropped photo on click. */}
  <div
    data-lightbox
    class="fixed inset-0 z-50 hidden cursor-zoom-out items-center justify-center bg-black/90 p-4"
  >
    <img data-lightbox-img alt={alt} class="max-h-full max-w-full object-contain" />
    <button
      type="button"
      data-lightbox-close
      aria-label="Close"
      class="absolute right-4 top-4 rounded-full border border-white/30 bg-black/40 px-3 py-1 font-mono text-lg text-white transition-colors hover:text-[var(--color-accent)]"
    >
      ✕
    </button>
  </div>
</div>

<style>
  .track::-webkit-scrollbar {
    display: none;
  }
  .track {
    scrollbar-width: none;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((root) => {
    const track = root.querySelector<HTMLElement>('[data-track]');
    if (!track) return;
    const prev = root.querySelector<HTMLButtonElement>('[data-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-next]');
    const dots = Array.from(root.querySelectorAll<HTMLElement>('[data-dot]'));
    const slides = Array.from(track.querySelectorAll<HTMLImageElement>('[data-slide-img]'));

    const setActive = () => {
      const i = Math.round(track.scrollLeft / track.clientWidth);
      dots.forEach((d, di) => (d.style.opacity = di === i ? '1' : '0.5'));
    };
    const go = (dir: number) => {
      track.scrollBy({ left: dir * track.clientWidth, behavior: 'smooth' });
    };

    prev?.addEventListener('click', () => go(-1));
    next?.addEventListener('click', () => go(1));
    track.addEventListener('scroll', () => requestAnimationFrame(setActive), { passive: true });
    setActive();

    // Lightbox: click a slide to view the full, uncropped image.
    const lightbox = root.querySelector<HTMLElement>('[data-lightbox]');
    const lightboxImg = root.querySelector<HTMLImageElement>('[data-lightbox-img]');
    const lightboxClose = root.querySelector<HTMLButtonElement>('[data-lightbox-close]');

    const open = (src: string) => {
      if (!lightbox || !lightboxImg) return;
      lightboxImg.src = src;
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      if (!lightbox) return;
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    };

    slides.forEach((img) => img.addEventListener('click', () => open(img.currentSrc || img.src)));
    lightbox?.addEventListener('click', close);
    lightboxClose?.addEventListener('click', close);
    // Don't close when clicking the image itself (only the backdrop / ✕).
    lightboxImg?.addEventListener('click', (e) => e.stopPropagation());
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox && !lightbox.classList.contains('hidden')) close();
    });
  });
</script>
