---
import type { CollectionEntry } from 'astro:content';
import { render, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { fmtDate, fmtKm } from '../../lib/format';
import { localeUrl } from '../../lib/url';
import { asset } from '../../lib/url';
import { t, type Locale } from '../../data/site';

interface Props {
  locale: Locale;
  trip: CollectionEntry<'trips'>;
}
const { locale, trip } = Astro.props;
const c = t(locale);
const { data } = trip;
const { Content } = await render(trip);

// Bike ridden: owned/past have a detail page; wishlist links out.
const ridden = data.bike ? await getEntry(data.bike) : undefined;
const bikeHref = ridden
  ? ridden.data.status === 'wishlist'
    ? ridden.data.link
    : localeUrl(locale, `/bikes/${ridden.id}`)
  : undefined;
---

<Layout title={data.title} description={`${data.region} · ${fmtKm(data.distanceKm, locale)}`}>
  <a href={localeUrl(locale, '/trips')} class="font-mono text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)]">
    {c.ui.backToTrips}
  </a>

  <article class="mt-4">
    <h1 class="font-mono text-3xl font-semibold tracking-tight">{data.title}</h1>
    <div class="mt-2 font-mono text-sm text-[var(--color-muted)]">
      {fmtDate(data.date, locale)} · {data.region}
    </div>
    <div class="mt-1 font-mono text-sm text-[var(--color-muted)]">
      {data.start} → {data.end} · {fmtKm(data.distanceKm, locale)}
    </div>

    {
      ridden && (
        <div class="mt-1 font-mono text-sm text-[var(--color-muted)]">
          {c.ui.ridden}{' '}
          {bikeHref ? (
            <a
              href={bikeHref}
              {...(ridden.data.status === 'wishlist'
                ? { target: '_blank', rel: 'noopener noreferrer' }
                : {})}
              class="text-[var(--color-accent)] hover:underline"
            >
              {ridden.data.make} {ridden.data.model}
              {ridden.data.status === 'wishlist' && ' ↗'}
            </a>
          ) : (
            <span>
              {ridden.data.make} {ridden.data.model}
            </span>
          )}
        </div>
      )
    }

    {data.cover && <img src={asset(data.cover)} alt="" class="mt-6 aspect-[2/1] w-full rounded-lg object-cover" />}

    <div class="prose mt-8">
      <Content />
    </div>
  </article>
</Layout>
