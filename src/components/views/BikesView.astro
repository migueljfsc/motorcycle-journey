---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BikeCard from '../BikeCard.astro';
import { t, type Locale } from '../../data/site';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const c = t(locale);

const bikes = await getCollection('bikes', ({ data }) => !data.draft);
---

<Layout title={c.pages.bikes.title} description={c.pages.bikes.description}>
  <h1 class="mb-6 font-mono text-3xl font-semibold tracking-tight">{c.pages.bikes.heading}</h1>

  {
    c.bikeGroups.map((g) => {
      const inGroup = bikes.filter((b) => b.data.status === g.status);
      if (inGroup.length === 0) return null;
      return (
        <section class="mb-10">
          <h2 class="mb-4 font-mono text-sm uppercase tracking-wide text-[var(--color-muted)]">
            {g.label}
          </h2>
          <div class="grid gap-5 sm:grid-cols-2">
            {inGroup.map((bike) => (
              <BikeCard bike={bike} />
            ))}
          </div>
        </section>
      );
    })
  }
</Layout>
