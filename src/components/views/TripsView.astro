---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import TripCard from '../TripCard.astro';
import { t, type Locale } from '../../data/site';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const c = t(locale);

const trips = (
  await getCollection('trips', ({ id, data }) => !data.draft && id.startsWith(`${locale}/`))
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group by year (newest first).
const years = [...new Set(trips.map((tr) => tr.data.date.getFullYear()))].sort((a, b) => b - a);
const byYear = years.map((year) => ({
  year,
  trips: trips.filter((tr) => tr.data.date.getFullYear() === year),
}));
---

<Layout title={c.pages.trips.title} description={c.pages.trips.description} wide>
  <h1 class="mb-6 font-mono text-3xl font-semibold tracking-tight">{c.pages.trips.heading}</h1>

  <div class="lg:grid lg:grid-cols-[110px_1fr] lg:gap-10">
    <!-- Year navigation (sticky on large screens) -->
    <aside class="hidden lg:block">
      <nav class="sticky top-24 flex flex-col gap-1 font-mono text-sm" data-tabs>
        {
          years.map((year) => (
            <a
              href={`#year-${year}`}
              data-tab={`year-${year}`}
              class="rounded px-3 py-1.5 text-[var(--color-muted)] transition-colors hover:text-[var(--color-accent)]"
            >
              {year}
            </a>
          ))
        }
      </nav>
    </aside>

    <div>
      {
        byYear.map((group) => (
          <section id={`year-${group.year}`} class="mb-12 scroll-mt-24">
            <h2 class="mb-4 border-b border-[var(--color-border)] pb-2 font-mono text-xl font-semibold">
              {group.year}
            </h2>
            <div class="grid gap-5 sm:grid-cols-2">
              {group.trips.map((trip) => (
                <TripCard trip={trip} />
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</Layout>

<script>
  // Scrollspy: highlight the year whose section is in view (matches the bike pages).
  const tabLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('[data-tab]'));
  const sections = tabLinks
    .map((l) => document.getElementById(l.dataset.tab!))
    .filter((s): s is HTMLElement => s !== null);

  if (tabLinks.length > 0 && sections.length > 0) {
    const offset = 130;
    const setActive = () => {
      let currentId = sections[0].id;
      for (const s of sections) {
        if (s.getBoundingClientRect().top <= offset) currentId = s.id;
      }
      if (window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 2) {
        currentId = sections[sections.length - 1].id;
      }
      for (const l of tabLinks) {
        const on = l.dataset.tab === currentId;
        l.style.color = on ? 'var(--color-accent)' : '';
        l.style.fontWeight = on ? '600' : '';
        l.style.borderLeft = on ? '2px solid var(--color-accent)' : '2px solid transparent';
      }
    };
    setActive();
    window.addEventListener('scroll', () => requestAnimationFrame(setActive), { passive: true });
    window.addEventListener('resize', setActive);
  }
</script>
