---
// Horizontal, non-looping carousel for arbitrary cards passed via the default slot.
// Wrap each item in a sizing element, e.g.
//   <div class="snap-start shrink-0 basis-[88%] sm:basis-[48%]">...</div>
---

<div class="card-carousel relative" data-ccarousel>
  <div
    class="ctrack flex gap-5 snap-x snap-mandatory overflow-x-auto scroll-smooth pb-2"
    data-ctrack
  >
    <slot />
  </div>

  <button
    type="button"
    data-cprev
    aria-label="Previous"
    class="absolute left-1 top-[40%] -translate-y-1/2 rounded-full border border-[var(--color-border)] bg-[var(--color-bg)]/85 px-3 py-1.5 font-mono text-sm backdrop-blur transition hover:text-[var(--color-accent)] disabled:cursor-default disabled:opacity-30"
  >
    ‹
  </button>
  <button
    type="button"
    data-cnext
    aria-label="Next"
    class="absolute right-1 top-[40%] -translate-y-1/2 rounded-full border border-[var(--color-border)] bg-[var(--color-bg)]/85 px-3 py-1.5 font-mono text-sm backdrop-blur transition hover:text-[var(--color-accent)] disabled:cursor-default disabled:opacity-30"
  >
    ›
  </button>
</div>

<style>
  .ctrack::-webkit-scrollbar {
    display: none;
  }
  .ctrack {
    scrollbar-width: none;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-ccarousel]').forEach((root) => {
    const track = root.querySelector<HTMLElement>('[data-ctrack]');
    const prev = root.querySelector<HTMLButtonElement>('[data-cprev]');
    const next = root.querySelector<HTMLButtonElement>('[data-cnext]');
    if (!track || !prev || !next) return;

    const update = () => {
      const overflow = track.scrollWidth > track.clientWidth + 1;
      // Hide controls entirely when there's nothing to scroll.
      prev.style.display = next.style.display = overflow ? '' : 'none';
      if (!overflow) return;
      const max = track.scrollWidth - track.clientWidth - 1;
      prev.disabled = track.scrollLeft <= 0; // no looping: stop at the start
      next.disabled = track.scrollLeft >= max; // no looping: stop at the end
    };
    const go = (dir: number) => {
      track.scrollBy({ left: dir * track.clientWidth * 0.9, behavior: 'smooth' });
    };

    prev.addEventListener('click', () => go(-1));
    next.addEventListener('click', () => go(1));
    track.addEventListener('scroll', () => requestAnimationFrame(update), { passive: true });
    window.addEventListener('resize', update);
    update();
  });
</script>
