---
import { localeUrl } from '../lib/url';
import { site, t, defaultLocale, type Locale } from '../data/site';
import LangToggle from './LangToggle.astro';

const locale = (Astro.currentLocale ?? defaultLocale) as Locale;
const c = t(locale);

// Active tab by first path segment, base- and locale-stripped.
const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname.replace(base, '/').replace(/^\/(pt)(?=\/|$)/, '/').replace(/\/+/g, '/');
const seg = '/' + (path.split('/').filter(Boolean)[0] ?? '');
---

<nav class="border-b border-[var(--color-border)] bg-[var(--color-bg)]/90 sticky top-0 z-10 backdrop-blur">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-5 py-4">
    <a href={localeUrl(locale, '/')} class="font-mono text-lg font-semibold tracking-tight">
      <span class="text-[var(--color-accent)]">▲</span> {site.brand}
    </a>
    <div class="flex items-center gap-3">
      <div class="flex gap-1 font-mono text-sm">
        {
          c.nav.map((tab) => (
            <a
              href={localeUrl(locale, tab.href)}
              class:list={[
                'rounded px-3 py-1.5 transition-colors hover:text-[var(--color-accent)]',
                seg === tab.href ? 'text-[var(--color-accent)]' : 'text-[var(--color-text)]',
              ]}
            >
              {tab.label}
            </a>
          ))
        }
      </div>
      <span class="text-[var(--color-border)]">|</span>
      <LangToggle />
    </div>
  </div>
</nav>
