---
import { url } from '../lib/url';

const tabs = [
  { label: 'Trips', href: '/trips' },
  { label: 'Tips', href: '/tips' },
  { label: 'Bikes', href: '/bikes' },
];

// Active tab by first path segment, base-stripped.
const path = Astro.url.pathname.replace(import.meta.env.BASE_URL, '/').replace(/\/+/g, '/');
const seg = '/' + (path.split('/').filter(Boolean)[0] ?? '');
---

<nav class="border-b border-[var(--color-border)] bg-[var(--color-bg)]/90 sticky top-0 z-10 backdrop-blur">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-5 py-4">
    <a href={url('/')} class="font-mono text-lg font-semibold tracking-tight">
      <span class="text-[var(--color-accent)]">▲</span> moto journey
    </a>
    <div class="flex gap-1 font-mono text-sm">
      {
        tabs.map((t) => (
          <a
            href={url(t.href)}
            class:list={[
              'rounded px-3 py-1.5 transition-colors hover:text-[var(--color-accent)]',
              seg === t.href ? 'text-[var(--color-accent)]' : 'text-[var(--color-muted)]',
            ]}
          >
            {t.label}
          </a>
        ))
      }
    </div>
  </div>
</nav>
