# Copy to backend.hcl (gitignored) and fill in your account id.
# State lives in an R2 bucket via the S3-compatible backend.
# Credentials come from env: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY = an R2 API token.
#
#   terraform init -backend-config=backend.hcl

bucket = "terraform-tfstate" # shared state bucket across personal projects
key    = "motorcycle-journey/cloudflare/terraform.tfstate"
region = "auto"

endpoints = {
  s3 = "https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
}

# R2 isn't AWS — skip the AWS-specific preflight checks.
skip_credentials_validation = true
skip_region_validation      = true
skip_requesting_account_id  = true
skip_metadata_api_check     = true
skip_s3_checksum            = true
use_path_style              = true
